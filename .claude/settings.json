{
  "extraKnownMarketplaces": {
    "lume": {
      "source": {
        "source": "directory",
        "path": "."
      }
    }
  },
  "enabledPlugins": {
    "lume@lume": true
  },
  "permissions": {
    "allow": [
      "Bash(plugin/bin/lume:*)",
      "Bash(lume:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR}/.claude/hooks/require-workstream-commit.py"
          }
        ]
      }
    ]
  }
}
