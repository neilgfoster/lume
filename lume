#!/usr/bin/env python3
"""Lume - deterministic control layer for the iteration loop.

v1 surface: `lume` (or `lume status`) prints the re-orientation for the
single active workstream. No inference anywhere in this path - it only
reads and parses the on-disk state files.
"""
import sys
from pathlib import Path

PHASES = {"proposed", "approved", "working", "handback", "accepted", "rejected"}


def find_lume_dir(start: Path) -> Path | None:
    """Walk up from `start` looking for a `.lume/` directory."""
    for d in (start, *start.parents):
        candidate = d / ".lume"
        if candidate.is_dir():
            return candidate
    return None


def find_workstreams(lume_dir: Path) -> list[Path]:
    """A workstream is any subdir of .lume/ holding an objective.md."""
    return sorted(p for p in lume_dir.iterdir() if (p / "objective.md").is_file())


def parse_frontmatter(text: str) -> dict[str, str]:
    """Parse a leading `--- ... ---` block of `key: value` lines."""
    lines = text.splitlines()
    if not lines or lines[0].strip() != "---":
        return {}
    out: dict[str, str] = {}
    for line in lines[1:]:
        if line.strip() == "---":
            break
        if ":" in line:
            key, _, value = line.partition(":")
            out[key.strip()] = value.strip()
    return out


def current_iteration(ws: Path) -> tuple[str, dict[str, str]] | None:
    """Highest-numbered iteration file and its frontmatter."""
    it_dir = ws / "iterations"
    if not it_dir.is_dir():
        return None
    files = sorted(it_dir.glob("*.md"))
    if not files:
        return None
    latest = files[-1]
    return latest.name, parse_frontmatter(latest.read_text())


def first_line(text: str) -> str:
    for line in text.splitlines():
        stripped = line.lstrip("# ").strip()
        if stripped:
            return stripped
    return "(empty)"


def done_now_next(snapshot: str) -> str:
    """Verbatim slice of the snapshot from the first `## Done` to EOF."""
    lines = snapshot.splitlines()
    for i, line in enumerate(lines):
        if line.strip().lower().startswith("## done"):
            return "\n".join(lines[i:]).rstrip()
    return snapshot.rstrip()


def status() -> int:
    lume_dir = find_lume_dir(Path.cwd())
    if lume_dir is None:
        print("lume: no .lume/ workstream found from here.", file=sys.stderr)
        return 1
    workstreams = find_workstreams(lume_dir)
    if not workstreams:
        print(f"lume: no workstream under {lume_dir} (need a subdir with objective.md).", file=sys.stderr)
        return 1
    if len(workstreams) > 1:
        names = ", ".join(p.name for p in workstreams)
        print(f"lume: v1 expects one workstream; found {len(workstreams)} ({names}). Showing first.", file=sys.stderr)
    ws = workstreams[0]

    objective = first_line((ws / "objective.md").read_text())
    it = current_iteration(ws)
    if it is None:
        it_line = "iteration: (none yet)"
    else:
        name, fm = it
        phase = fm.get("phase", "?")
        warn = "" if phase in PHASES else "  [!] unknown phase"
        it_line = f"iteration {fm.get('id', name)}: phase {phase}{warn}"

    snap_file = ws / "snapshot.md"
    snap = done_now_next(snap_file.read_text()) if snap_file.is_file() else "(no snapshot)"

    print(f"# {ws.name}")
    print(f"objective: {objective}")
    print(it_line)
    print()
    print(snap)
    return 0


def main(argv: list[str]) -> int:
    cmd = argv[1] if len(argv) > 1 else "status"
    if cmd == "status":
        return status()
    print(f"lume: unknown command '{cmd}' (v1 supports: status)", file=sys.stderr)
    return 2


if __name__ == "__main__":
    raise SystemExit(main(sys.argv))
