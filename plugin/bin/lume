#!/usr/bin/env python3
"""Executable entry point. Puts the engine package on the path and dispatches.

`lume` lives in the plugin/repo root; the engine package is `src/lume` (src
layout). This file is `bin/lume`, so the package root is `<parent.parent>/src`,
resolved from this file's own location - no hard-coded path. When installed as a
Claude plugin, bin/ is on PATH and this is invoked as a bare `lume`. The engine
then locates the operator's state by walking up from the working directory for a
`.lume/` directory.

    lume status
    lume open "Some title"
"""
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent.parent / "src"))

from lume.cli import main  # noqa: E402  (path set up above)

if __name__ == "__main__":
    raise SystemExit(main(sys.argv))
