{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "retro",
  "type": "object",
  "required": ["overall_verdict", "carry_forwards"],
  "properties": {
    "stage_verdicts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["stage", "cost", "saved", "net"],
        "properties": {
          "stage":      {"type": "string"},
          "iterations": {"type": "string"},
          "cost":       {"type": "string"},
          "saved":      {"type": "string"},
          "net":        {"type": "string"}
        }
      }
    },
    "done_when": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["clause", "verdict", "evidence"],
        "properties": {
          "clause":   {"type": "string"},
          "verdict":  {"type": "string"},
          "evidence": {"type": "string"}
        }
      }
    },
    "overall_verdict":  {"type": "string"},
    "carry_forwards": {
      "type": "array",
      "items": {"type": "string"}
    },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["heading", "body"],
        "properties": {
          "heading": {"type": "string"},
          "body":    {"type": "string"}
        }
      }
    }
  }
}
